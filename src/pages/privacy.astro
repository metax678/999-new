---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Privacy Policy — RADIANX CAPITAL"
  description="Privacy policy for RADIANX CAPITAL, LLC covering data collection, use, security and your rights under Regulation S-P."
  currentPath="/privacy"
>

<header class="ph">
  <div class="ph-atm"></div>
  <div class="ph-geo">
    <svg viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" fill="none">
      <g transform="translate(1200,250)">
        <g class="rot"><circle cx="0" cy="0" r="210" stroke="rgba(240,238,235,.022)" stroke-width="1" fill="none"/><path d="M0,-210 A210,210 0 0,1 148,148" stroke="rgba(240,238,235,.048)" stroke-width="1.5" fill="none" stroke-linecap="round"/></g>
        <g class="rotr"><circle cx="0" cy="0" r="270" stroke="rgba(240,238,235,.012)" stroke-width="1" fill="none" stroke-dasharray="3,8"/></g>
      </g>
    </svg>
  </div>
  <div class="ph-inner">
    <div class="sec-tag rv">Legal</div>
    <h1 class="ph-h rv">Privacy<br><em>Policy</em></h1>
    <p class="ph-desc rv">RADIANX CAPITAL, LLC is committed to protecting the privacy and confidentiality of personal information entrusted to it by clients, prospective clients, and visitors to this website. This Privacy Policy explains how we collect, use, share, and protect that information.</p>
    <div class="ph-meta rv">
      <div class="ph-date">Effective Date: January 1, 2025 &nbsp;·&nbsp; Last Reviewed: January 2025</div>
      <div class="ph-jumps">
        <a href="#collect" class="ph-jump">Collection</a>
        <a href="#use" class="ph-jump">Use</a>
        <a href="#share" class="ph-jump">Sharing</a>
        <a href="#security" class="ph-jump">Security</a>
        <a href="#rights" class="ph-jump">Your Rights</a>
        <a href="#cookies" class="ph-jump">Cookies</a>
        <a href="#contact-pp" class="ph-jump">Contact</a>
      </div>
    </div>
  </div>
</header>

<div class="wrap">
  <aside class="sb">
    
  </aside>

  <main class="main">

    <div class="ps" id="collect">
      <div class="ps-tag rv">01</div>
      <h2 class="ps-h rv">Information We <em>Collect</em></h2>
      <p class="body rv">We collect personal information in the ordinary course of providing investment advisory services and operating our website. The categories and sources of information we collect are described below.</p>
      <div class="sub-tag rv">Information provided directly by you</div>
      <div class="plist rv">
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Identity Information:</strong> Full name, date of birth, Social Security number or Tax Identification Number, government-issued identification.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Contact Information:</strong> Mailing address, email address, telephone number.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Financial Information:</strong> Account numbers, asset values, income, net worth, tax records, investment experience, risk tolerance, and financial objectives.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Transaction Information:</strong> Records of transactions in your accounts, including purchases, sales, transfers, and distributions.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Communication Records:</strong> Records of correspondence and meeting notes exchanged between you and RADIANX CAPITAL personnel.</div></div>
      </div>
      <div class="sub-tag rv" style="margin-top:28px">Information collected automatically via website</div>
      <div class="plist rv">
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Usage Data:</strong> Pages visited, time on page, referring URLs, browser type, operating system, and device identifiers.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Log Data:</strong> IP address, access timestamps, and server log data generated when you access our website.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Cookie Data:</strong> Information stored in cookies and similar technologies, as described in the Cookies section below.</div></div>
      </div>
      <div class="sub-tag rv" style="margin-top:28px">Information received from third parties</div>
      <div class="plist rv">
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Custodians and Brokers:</strong> Account statements, trade confirmations, and other records from financial institutions that hold your assets.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Public Sources:</strong> Publicly available information relevant to providing advisory services, such as public records and regulatory filings.</div></div>
      </div>
    </div>

    <div class="ps" id="use">
      <div class="ps-tag rv">02</div>
      <h2 class="ps-h rv">How We <em>Use</em> Your Information</h2>
      <p class="body rv">We use personal information only for lawful purposes directly related to our advisory services and business operations. We do not use personal information for purposes incompatible with those for which it was originally collected without your consent.</p>
      <div class="tbl rv">
        <div class="tbl-head"><div class="tbl-hc">Purpose</div><div class="tbl-hc">Lawful Basis</div><div class="tbl-hc">Examples</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Providing Advisory Services</div><div class="tbl-c">Contractual obligation</div><div class="tbl-c">Portfolio management, financial planning, investment recommendations</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Regulatory Compliance</div><div class="tbl-c">Legal obligation</div><div class="tbl-c">AML/KYC, SEC reporting, Form ADV maintenance</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Account Administration</div><div class="tbl-c">Contractual obligation</div><div class="tbl-c">Account opening, billing, record-keeping, correspondence</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Communication</div><div class="tbl-c">Legitimate interest</div><div class="tbl-c">Responding to enquiries, account updates, regulatory notices</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Service Improvement</div><div class="tbl-c">Legitimate interest</div><div class="tbl-c">Website analytics, platform feature improvement</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Fraud Prevention</div><div class="tbl-c">Legal obligation / Legitimate interest</div><div class="tbl-c">Identity verification, suspicious activity monitoring</div></div>
      </div>
      <div class="ibox rv">
        <div class="ibox-lbl">No Sale of Personal Information</div>
        <p class="ibox-txt">RADIANX CAPITAL, LLC does not sell, rent, or otherwise transfer personal information to third parties for their marketing purposes. Personal information is used exclusively as described in this Privacy Policy.</p>
      </div>
    </div>

    <div class="ps" id="share">
      <div class="ps-tag rv">03</div>
      <h2 class="ps-h rv">How We <em>Share</em> Information</h2>
      <p class="body rv">We may disclose personal information to third parties in limited circumstances as described below. In all cases, we require third parties to handle personal information consistently with this Policy and applicable law.</p>
      <div class="plist rv">
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Custodians and Broker-Dealers:</strong> We share account information with the financial institutions that custody your assets and execute transactions on your behalf.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Service Providers:</strong> Third-party vendors including technology providers, compliance consultants, and administrators who process personal information on our behalf under written data processing agreements.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Professional Advisers:</strong> With your consent, we may share information with your attorneys, accountants, or other professionals involved in your financial planning.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Regulatory and Legal Requirements:</strong> We may disclose personal information to regulators, law enforcement, or courts when required by applicable law, regulation, or governmental request.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Business Transfers:</strong> In connection with a merger, acquisition, or sale of assets, personal information may be transferred to a successor entity. We will notify affected clients prior to any such transfer.</div></div>
      </div>
      <p class="body rv">We do not share personal information with unaffiliated third parties for their own marketing or commercial purposes without your explicit consent.</p>
    </div>

    <div class="ps" id="security">
      <div class="ps-tag rv">04</div>
      <h2 class="ps-h rv">Information <em>Security</em></h2>
      <p class="body rv">We maintain a comprehensive information security programme designed to protect personal information from unauthorised access, disclosure, alteration, and destruction.</p>
      <div class="plist rv">
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Technical Safeguards:</strong> Encryption of data in transit (TLS) and at rest, secure access controls, multi-factor authentication, and regular security assessments.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Physical Safeguards:</strong> Restricted office access, secure disposal of paper records, and locked storage for sensitive documents.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Administrative Safeguards:</strong> Privacy training for all personnel, written information security policies, access controls based on need-to-know, and regular policy review.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Incident Response:</strong> A written incident response plan governing notification and remediation in the event of a data security breach, consistent with applicable notification laws.</div></div>
      </div>
      <div class="ibox rv">
        <div class="ibox-lbl">Security Limitation</div>
        <p class="ibox-txt">No security system is impenetrable. We cannot guarantee the absolute security of information transmitted over the internet. We encourage clients to use strong passwords, protect their login credentials, and notify us immediately if they suspect unauthorised access to their account.</p>
      </div>
    </div>

    <div class="ps" id="retention">
      <div class="ps-tag rv">05</div>
      <h2 class="ps-h rv">Data <em>Retention</em></h2>
      <p class="body rv">We retain personal information for as long as necessary to fulfil the purposes described in this Policy, to comply with legal and regulatory obligations, and to resolve disputes.</p>
      <div class="tbl rv" style="margin-top:24px">
        <div class="tbl-head"><div class="tbl-hc">Category</div><div class="tbl-hc">Retention Period</div><div class="tbl-hc">Regulatory Basis</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Client Account Records</div><div class="tbl-c">5 years after termination</div><div class="tbl-c">SEC Rule 204-2</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Transaction Records</div><div class="tbl-c">5 years from transaction date</div><div class="tbl-c">SEC Rule 204-2</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Written Communications</div><div class="tbl-c">5 years</div><div class="tbl-c">SEC Rule 204-2</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Website &amp; Enquiry Data</div><div class="tbl-c">2 years from last interaction</div><div class="tbl-c">Legitimate interest</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Tax &amp; Compliance Records</div><div class="tbl-c">7 years minimum</div><div class="tbl-c">IRS / state law</div></div>
      </div>
      <p class="body rv">Following the applicable retention period, personal information is securely destroyed in accordance with our data disposal procedures.</p>
    </div>

    <div class="ps" id="rights">
      <div class="ps-tag rv">06</div>
      <h2 class="ps-h rv">Your Privacy <em>Rights</em></h2>
      <p class="body rv">Subject to applicable law, you have certain rights with respect to your personal information. These rights may vary depending on your state of residence.</p>
      <div class="plist rv">
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Right to Access:</strong> Request a copy of the personal information we hold about you, including how it is being used.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Right to Correction:</strong> Request correction of inaccurate or incomplete personal information. We encourage clients to notify us promptly of any changes.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Right to Deletion:</strong> In certain circumstances, request deletion of your personal information, subject to applicable retention requirements.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Right to Opt Out of Sharing:</strong> Direct us not to share your personal information with unaffiliated third parties for marketing purposes. We do not engage in such sharing.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Right to Non-Discrimination:</strong> We will not discriminate against you for exercising any of your privacy rights.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>California Residents (CCPA/CPRA):</strong> Additional rights including the right to know, delete, correct, and opt out of the sale or sharing of personal information.</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t"><strong>Vermont Residents:</strong> Consistent with Vermont's financial privacy law, we will not disclose non-public personal information to nonaffiliated third parties except as permitted by law or with prior consent.</div></div>
      </div>
      <p class="body rv">To exercise any of these rights, contact us using the information in the Contact section. We will acknowledge receipt within 10 business days and respond fully within the timeframe required by applicable law.</p>
    </div>

    <div class="ps" id="cookies">
      <div class="ps-tag rv">07</div>
      <h2 class="ps-h rv">Cookies &amp; Tracking<br><em>Technologies</em></h2>
      <p class="body rv">Our website uses cookies and similar tracking technologies to improve your browsing experience, analyse website usage, and support website functionality.</p>
      <div class="tbl rv" style="margin-top:24px">
        <div class="tbl-head"><div class="tbl-hc">Cookie Type</div><div class="tbl-hc">Purpose</div><div class="tbl-hc">Duration</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Strictly Necessary</div><div class="tbl-c">Required for basic website functionality; cannot be disabled</div><div class="tbl-c">Session</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Analytics</div><div class="tbl-c">Understanding usage patterns to improve content and user experience</div><div class="tbl-c">Up to 2 years</div></div>
        <div class="tbl-row"><div class="tbl-c bold">Preference</div><div class="tbl-c">Remembering your settings and preferences for future visits</div><div class="tbl-c">Up to 1 year</div></div>
      </div>
      <p class="body rv">You can control cookies through your browser settings. Disabling cookies may affect the functionality of certain parts of our website. We do not use cookies for advertising or cross-site tracking purposes.</p>
      <div class="ibox rv">
        <div class="ibox-lbl">Do Not Track</div>
        <p class="ibox-txt">Our website does not currently respond to "Do Not Track" browser signals, as there is no industry-wide standard for compliance. We will update this policy if a recognised standard is established.</p>
      </div>
    </div>

    <div class="ps" id="third">
      <div class="ps-tag rv">08</div>
      <h2 class="ps-h rv">Third-Party <em>Links</em></h2>
      <p class="body rv">Our website may contain links to third-party websites, including the SEC's IAPD system, financial data providers, and other external resources. This Privacy Policy applies only to radianx.io and information collected directly by RADIANX CAPITAL, LLC.</p>
      <p class="body rv">We are not responsible for the privacy practices of third-party websites. We encourage you to review the privacy policies of any third-party website you visit through links on our site. Inclusion of a link does not constitute an endorsement of that third party's privacy practices.</p>
    </div>

    <div class="ps" id="children">
      <div class="ps-tag rv">09</div>
      <h2 class="ps-h rv">Children's <em>Privacy</em></h2>
      <p class="body rv">Our website and services are intended for adults only. We do not knowingly collect personal information from individuals under the age of 18. If you believe that a minor has provided us with personal information without parental consent, please contact us immediately and we will take steps to delete such information promptly.</p>
    </div>

    <div class="ps" id="changes">
      <div class="ps-tag rv">10</div>
      <h2 class="ps-h rv">Changes to This <em>Policy</em></h2>
      <p class="body rv">We may update this Privacy Policy from time to time to reflect changes in our practices, applicable law, or regulatory requirements. When we make material changes, we will:</p>
      <div class="plist rv">
        <div class="pl"><div class="pl-d">—</div><div class="pl-t">Update the "Last Reviewed" date at the top of this policy</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t">Post the updated policy at radianx.io/privacy</div></div>
        <div class="pl"><div class="pl-d">—</div><div class="pl-t">Notify existing clients in writing if changes materially affect how we use their personal information</div></div>
      </div>
      <p class="body rv">Your continued use of our website or advisory services following the effective date of any updated policy constitutes your acceptance of the changes.</p>
      <div class="rule rv"></div>
      <p class="body rv" style="font-size:13px;color:var(--white3)">This Privacy Policy is provided in compliance with Regulation S-P (Privacy of Consumer Financial Information) under the Securities Exchange Act of 1934, and applicable state privacy laws including the California Consumer Privacy Act (CCPA) and California Privacy Rights Act (CPRA). Last reviewed January 2025.</p>
    </div>

    <div class="ps" id="contact-pp">
      <div class="ps-tag rv">11</div>
      <h2 class="ps-h rv">Privacy <em>Contact</em></h2>
      <p class="body rv">For questions about this Privacy Policy, to exercise your privacy rights, or to make a privacy-related request, please contact us using the information below.</p>
      <div class="dgrid rv">
        <div class="dg"><div class="dg-l">Privacy Officer</div><div class="dg-v">RADIANX CAPITAL, LLC<br>Attn: Privacy Officer</div></div>
        <div class="dg"><div class="dg-l">Mailing Address</div><div class="dg-v">529 5th Avenue, Suite 1475<br>New York, NY 10017</div></div>
        <div class="dg"><div class="dg-l">Email</div><div class="dg-v"><a href="mailto:privacy@radianx.io">privacy@radianx.io</a></div></div>
        <div class="dg"><div class="dg-l">Telephone</div><div class="dg-v"><a href="tel:6464033807">(646) 403-3807</a></div></div>
      </div>
      <p class="body rv">You also have the right to file a complaint with your applicable state privacy regulator or the U.S. Federal Trade Commission if you believe your privacy rights have been violated. We encourage you to contact us first so that we have an opportunity to address your concern directly.</p>
    </div>

  </main>
</div>

<section class="cta">
  <h2 class="cta-h rv">Questions about<br>how we handle<br>your <em>information?</em></h2>
  <div class="cta-r rv">
    <p class="cta-b">We take privacy seriously and welcome your questions. Reach out to our privacy team directly — we respond to all enquiries promptly and with complete transparency.</p>
    <div class="cta-btns">
      <a href="mailto:privacy@radianx.io" class="btn-a">Email Privacy Team</a>
      <a href="/contact" class="btn-b">General Contact</a>
    </div>
  </div>
</section>

<div class="f-bot">
  <p class="f-disc">RADIANX CAPITAL, LLC is an SEC-registered investment adviser (CRD# 298178 · SEC# 801-117100). This Privacy Policy is provided pursuant to Regulation S-P and applicable state privacy laws including CCPA/CPRA. © 2025 RADIANX CAPITAL, LLC. All rights reserved.</p>
  <div class="f-url">radianx.io/privacy</div>
</div>

</Layout>



<script is:inline>
const cur=document.getElementById('cur'),curR=document.getElementById('curR');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
(function a(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;curR.style.left=rx+'px';curR.style.top=ry+'px';requestAnimationFrame(a)})();
document.querySelectorAll('a,button,.dg,.tbl-row,.pl').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.transform='translate(-50%,-50%) scale(2)';curR.style.width='56px';curR.style.height='56px'});
  el.addEventListener('mouseleave',()=>{cur.style.transform='translate(-50%,-50%) scale(1)';curR.style.width='32px';curR.style.height='32px'});
});
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('s',scrollY>50));
const io=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('in');io.unobserve(x.target)}}),{threshold:.06});
document.querySelectorAll('.rv').forEach(el=>io.observe(el));
const secs=document.querySelectorAll('.ps');
const sbs=document.querySelectorAll('.sb-a');
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){sbs.forEach(i=>i.classList.remove('on'));const a=document.querySelector('.sb-a[href="#'+e.target.id+'"]');if(a)a.classList.add('on')}});
},{threshold:.3});
secs.forEach(s=>obs.observe(s));
document.querySelectorAll('a[href^="#"]').forEach(a=>a.addEventListener('click',e=>{
  const t=document.querySelector(a.getAttribute('href'));
  if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'})}
}));
</script>
