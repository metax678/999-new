</style>

<script is:inline>
/* ── Scroll reveal ── */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
  });
}, { threshold: 0.08 });
document.querySelectorAll('.rv').forEach(el => io.observe(el));

/* ── Service card chip filter ── */
document.querySelectorAll('.chip').forEach(chip => {
  chip.addEventListener('click', () => {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('on'));
    chip.classList.add('on');
    const key = chip.dataset.key;
    document.querySelectorAll('.srv-card').forEach(card => {
      card.hidden = key !== 'all' && card.dataset.key !== key;
    });
  });
});

/* ── Stat counter animation ── */
const countIO = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target;
    const raw = el.textContent.trim();
    const match = raw.match(/^(\D*)(\d+\.?\d*)(\D*)$/);
    if (!match) return;
    const [, pre, num, post] = match;
    const target = parseFloat(num);
    const isDecimal = num.includes('.');
    const duration = 1400;
    const start = performance.now();
    function tick(now) {
      const t = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - t, 4);
      const val = ease * target;
      el.textContent = pre + (isDecimal ? val.toFixed(1) : Math.floor(val)) + post;
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
    countIO.unobserve(el);
  });
}, { threshold: 0.5 });
document.querySelectorAll('.sbar-num').forEach(el => countIO.observe(el));

/* ── Cursor glow on dark sections ── */
const glow = document.createElement('div');
glow.className = 'cursor-glow';
document.body.appendChild(glow);
let glowVisible = false;

document.addEventListener('mousemove', e => {
  glow.style.left = e.clientX + 'px';
  glow.style.top  = e.clientY + 'px';
  const el = document.elementFromPoint(e.clientX, e.clientY);
  const inDark = el?.closest('.approach-band, .cta-section, section[style*="bg2"]');
  if (inDark && !glowVisible) { glow.style.opacity = '1'; glowVisible = true; }
  else if (!inDark && glowVisible) { glow.style.opacity = '0'; glowVisible = false; }
});

/* ── Service card magnetic hover ── */
document.querySelectorAll('.srv-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    const x = ((e.clientX - r.left) / r.width  - 0.5) * 8;
    const y = ((e.clientY - r.top)  / r.height - 0.5) * 8;
    card.style.transform = `perspective(600px) rotateX(${-y}deg) rotateY(${x}deg) translateY(-3px)`;
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = '';
  });
});

/* ── Testimonial card parallax text ── */
document.querySelectorAll('.testi-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    const x = (e.clientX - r.left) / r.width  - 0.5;
    const y = (e.clientY - r.top)  / r.height - 0.5;
    const txt = card.querySelector('.testi-text');
    if (txt) txt.style.transform = `translate(${x * 4}px, ${y * 4}px)`;
  });
  card.addEventListener('mouseleave', () => {
    const txt = card.querySelector('.testi-text');
    if (txt) txt.style.transform = '';
  });
});

/* ── Navbar scroll effect ── */
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', scrollY > 40);
}, { passive: true });
</script>
