.val-grid { list-style: none; margin: 28px 0 36px; display: flex; flex-direction: column; }
.val-item { display: grid; grid-template-columns: 28px 1fr; gap: 14px; padding: 18px 0; border-bottom: 1px solid #f0eeea; transition: padding-left .2s; }
.val-item:first-child { border-top: 1px solid #f0eeea; }
