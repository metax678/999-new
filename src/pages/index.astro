---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RADIANX CAPITAL — Precision Wealth Management · New York">

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <p class="h-label rv">
        <span></span>
        SEC Registered Investment Adviser · New York
        <span></span>
      </p>
      <h1 class="hero-h rv">
        Where Precision<br>
        <em>Meets</em> Capital.
      </h1>
      <p class="hero-sub rv">
        A <strong>fiduciary investment adviser</strong> managing nearly
        $1 billion in assets for high-net-worth individuals,
        families, and institutions — since 2017.
      </p>
      <div class="hero-btns rv">
        <a href="/contact" class="btn-primary">Get Started</a>
        <a href="/services" class="btn-secondary">Our Services</a>
      </div>
    </div>
    <div class="hero-meta rv">
      {['SEC Registered','Fiduciary Standard','Fee-Only','$953M+ AUM','Est. 2017, New York'].map(t => (
        <span class="hero-tag">{t}</span>
      ))}
    </div>
  </section>


  <!-- ══ PRESS LOGOS ══ -->
  <div class="press-bar">
    <span class="press-label">As Seen In</span>
    <div class="press-track-wrap">
      <div class="press-track">
        <span class="press-item">The Wall Street Journal</span>
        <span class="press-sep">·</span>
        <span class="press-item">Bloomberg</span>
        <span class="press-sep">·</span>
        <span class="press-item">Forbes</span>
        <span class="press-sep">·</span>
        <span class="press-item">Financial Times</span>
        <span class="press-sep">·</span>
        <span class="press-item">Barron's</span>
        <span class="press-sep">·</span>
        <span class="press-item">CNBC</span>
        <span class="press-sep">·</span>
        <span class="press-item">Reuters</span>
        <span class="press-sep">·</span>
        <span class="press-item">The Wall Street Journal</span>
        <span class="press-sep">·</span>
        <span class="press-item">Bloomberg</span>
        <span class="press-sep">·</span>
        <span class="press-item">Forbes</span>
        <span class="press-sep">·</span>
        <span class="press-item">Financial Times</span>
        <span class="press-sep">·</span>
        <span class="press-item">Barron's</span>
        <span class="press-sep">·</span>
        <span class="press-item">CNBC</span>
        <span class="press-sep">·</span>
        <span class="press-item">Reuters</span>
      </div>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats-bar">
    {[
      {num:'$953M+', label:'Assets Under Management', sub:'Current SEC filing'},
      {num:'8+',     label:'Years in Operation',      sub:'Founded Nov 2017'},
      {num:'100%',   label:'Fiduciary Standard',      sub:'Always'},
      {num:'SEC',    label:'Registered Adviser',      sub:'No. 801-117100'},
    ].map((s,i) => (
      <div class={`sbar rv${i>0?` d${i}`:''}`}>
        <div class="sbar-num">{s.num}</div>
        <div class="sbar-label">{s.label}</div>
        <div class="sbar-sub">{s.sub}</div>
      </div>
    ))}
  </div>

  <!-- PHOTO STRIP -->
  <div class="photo-strip">
    <img src="/images/hero-office.jpg" alt="RADIANX CAPITAL office, Midtown Manhattan" loading="lazy"/>
    <div class="photo-strip-overlay"></div>
    <p class="photo-strip-txt">Eight years of<br><em>measured conviction.</em></p>
    <span class="photo-year">New York · Est. 2017</span>
  </div>

  <!-- SERVICES -->

  <!-- ══ FEATURES ══ -->

  <!-- ══ PLATFORM SECTION ══ -->
  <section class="platform-section">
    <div class="platform-inner">

      <div class="platform-header rv">
        <div class="platform-tag">Beyond Wealth Management</div>
        <h2 class="platform-h">Three ways to grow<br><em>your capital.</em></h2>
        <p class="platform-sub">RADIANX operates across the full spectrum of capital markets — from long-term wealth management to active trading and spot execution.</p>
      </div>

      <div class="platform-grid">

        <div class="platform-card rv">
          <div class="pc-icon">
            <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
              <path d="M4 24L12 14l6 6 10-12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="14" r="1.5" fill="currentColor"/>
              <circle cx="18" cy="20" r="1.5" fill="currentColor"/>
            </svg>
          </div>
          <div class="pc-num">01</div>
          <h3 class="pc-title">Wealth Management</h3>
          <p class="pc-desc">Bespoke portfolio construction, financial planning, tax optimisation and estate strategy — built entirely around your long-term objectives as a fiduciary adviser.</p>
          <ul class="pc-list">
            <li>SEC-registered fiduciary</li>
            <li>Custom portfolio construction</li>
            <li>Integrated tax & estate planning</li>
          </ul>
          <a href="/services" class="pc-link">Explore Services →</a>
        </div>

        <div class="platform-card platform-card-accent rv d1">
          <div class="pc-icon">
            <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
              <rect x="3" y="18" width="5" height="9" rx="1" stroke="currentColor" stroke-width="1.8"/>
              <rect x="11" y="11" width="5" height="16" rx="1" stroke="currentColor" stroke-width="1.8"/>
              <rect x="19" y="5" width="5" height="22" rx="1" stroke="currentColor" stroke-width="1.8"/>
              <path d="M5.5 14l6-6 6 5 8-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="pc-num">02</div>
          <h3 class="pc-title">Active Trading</h3>
          <p class="pc-desc">Institutional-grade active trading strategies across equities, derivatives, and structured products — executed with disciplined risk frameworks and real-time market intelligence.</p>
          <ul class="pc-list">
            <li>Multi-asset class execution</li>
            <li>Quantitative & discretionary strategies</li>
            <li>Real-time risk management</li>
          </ul>
          <a href="/contact" class="pc-link">Start Trading →</a>
        </div>

        <div class="platform-card rv d2">
          <div class="pc-icon">
            <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
              <circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="1.8"/>
              <path d="M16 8v8l5 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <path d="M8 4l2 3M24 4l-2 3M4 24l3-2M28 24l-3-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="pc-num">03</div>
          <h3 class="pc-title">Spot Platform</h3>
          <p class="pc-desc">Direct access to spot markets with competitive pricing, deep liquidity, and institutional-level execution. Trade currencies, commodities, and digital assets with precision and speed.</p>
          <ul class="pc-list">
            <li>Competitive spot pricing</li>
            <li>Deep institutional liquidity</li>
            <li>Fast, reliable execution</li>
          </ul>
          <a href="/contact" class="pc-link">Access Platform →</a>
        </div>

      </div>

      <div class="platform-bottom rv">
        <div class="pb-stat">
          <div class="pb-val">$953M+</div>
          <div class="pb-label">Under Management</div>
        </div>
        <div class="pb-divider"></div>
        <div class="pb-stat">
          <div class="pb-val">3</div>
          <div class="pb-label">Capital Solutions</div>
        </div>
        <div class="pb-divider"></div>
        <div class="pb-stat">
          <div class="pb-val">8+</div>
          <div class="pb-label">Years Active</div>
        </div>
        <div class="pb-divider"></div>
        <div class="pb-stat">
          <div class="pb-val">SEC</div>
          <div class="pb-label">Registered & Regulated</div>
        </div>
      </div>

    </div>
  </section>

  <section class="features-section">

    <div class="feat feat-img-right">
      <div class="feat-text rv">
        <div class="feat-tag">Fiduciary First</div>
        <h2 class="feat-h">Your interests.<br><em>Always first.</em></h2>
        <p class="feat-body">As an SEC-registered investment adviser operating under the fiduciary standard, we are legally obligated to act in your best interest — at every moment, on every decision. No commissions. No conflicts of interest. Just clear, objective advice aligned entirely with your goals.</p>
        <ul class="feat-list">
          <li>No commission-based products, ever</li>
          <li>Full transparency on all fees and costs</li>
          <li>Objective advice with zero hidden incentives</li>
        </ul>
        <a href="/about" class="btn-outline rv">How We Operate →</a>
      </div>
      <div class="feat-visual rv">
        <div class="feat-card-stack">
          <div class="f-card f-card-1">
            <div class="f-card-label">Fiduciary Standard</div>
            <div class="f-card-val">100%</div>
            <div class="f-card-sub">Always legally bound to you</div>
          </div>
          <div class="f-card f-card-2">
            <div class="f-card-label">Commission Income</div>
            <div class="f-card-val">$0</div>
            <div class="f-card-sub">Zero. Not a single dollar.</div>
          </div>
          <div class="f-card f-card-3">
            <div class="f-card-label">SEC Registration</div>
            <div class="f-card-val">CRD# 298178</div>
            <div class="f-card-sub">Active since November 2017</div>
          </div>
        </div>
      </div>
    </div>

    <div class="feat feat-img-left">
      <div class="feat-visual rv">
        <div class="feat-chart-mock">
          <div class="fcm-label">Portfolio Performance</div>
          <div class="fcm-bars">
            <div class="fcm-bar" style="height:45%"><span>Q1</span></div>
            <div class="fcm-bar" style="height:62%"><span>Q2</span></div>
            <div class="fcm-bar" style="height:51%"><span>Q3</span></div>
            <div class="fcm-bar fcm-bar-hi" style="height:78%"><span>Q4</span></div>
            <div class="fcm-bar" style="height:58%"><span>Q1</span></div>
            <div class="fcm-bar fcm-bar-hi" style="height:84%"><span>Q2</span></div>
          </div>
          <div class="fcm-footer">Risk-adjusted returns · Bespoke to your profile</div>
        </div>
      </div>
      <div class="feat-text rv">
        <div class="feat-tag">Investment Management</div>
        <h2 class="feat-h">Portfolios built<br><em>from scratch.</em></h2>
        <p class="feat-body">We don't use model portfolios or pre-packaged products. Every portfolio is constructed from the ground up — calibrated to your specific goals, tax situation, time horizon, and risk tolerance. Then monitored and refined continuously as your life evolves.</p>
        <ul class="feat-list">
          <li>Custom allocation across all asset classes</li>
          <li>Continuous active risk management</li>
          <li>Tax-loss harvesting integrated at every level</li>
        </ul>
        <a href="/services#investment" class="btn-outline rv">Explore Investments →</a>
      </div>
    </div>

    <div class="feat feat-img-right">
      <div class="feat-text rv">
        <div class="feat-tag">Financial Planning</div>
        <h2 class="feat-h">A plan that<br><em>evolves with you.</em></h2>
        <p class="feat-body">Your financial plan is not a one-time document — it is a living framework that we revisit, stress-test, and refine as your life changes. We map every dimension: income, obligations, protection, education, retirement, and legacy — and keep it all in alignment.</p>
        <ul class="feat-list">
          <li>360° view of your complete financial life</li>
          <li>Integrated retirement & estate planning</li>
          <li>Regular reviews tied to life events</li>
        </ul>
        <a href="/services#planning" class="btn-outline rv">See Financial Planning →</a>
      </div>
      <div class="feat-visual rv">
        <div class="feat-timeline">
          <div class="ftl-item">
            <div class="ftl-dot"></div>
            <div class="ftl-content">
              <div class="ftl-label">Discovery</div>
              <div class="ftl-desc">Full financial picture mapped</div>
            </div>
          </div>
          <div class="ftl-item">
            <div class="ftl-dot"></div>
            <div class="ftl-content">
              <div class="ftl-label">Strategy Design</div>
              <div class="ftl-desc">Bespoke plan across all areas</div>
            </div>
          </div>
          <div class="ftl-item">
            <div class="ftl-dot"></div>
            <div class="ftl-content">
              <div class="ftl-label">Implementation</div>
              <div class="ftl-desc">Executed with institutional precision</div>
            </div>
          </div>
          <div class="ftl-item ftl-active">
            <div class="ftl-dot"></div>
            <div class="ftl-content">
              <div class="ftl-label">Continuous Review</div>
              <div class="ftl-desc">Adapts as your life evolves</div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </section>

  <section class="light-section" id="services">
    <div class="ls-inner">
      <div class="srv-head">
        <div>
          <div class="ls-tag rv">What We Offer</div>
          <h2 class="ls-h rv">Comprehensive<br><em>wealth services</em></h2>
        </div>
        <p class="srv-desc rv">Every service tailored to your individual financial architecture — not templated, not generic.</p>
      </div>

      <div class="chips rv" id="chips">
        {[
          {key:'all',  label:'All Services'},
          {key:'inv',  label:'Investment Management'},
          {key:'plan', label:'Financial Planning'},
          {key:'tax',  label:'Tax Optimization'},
          {key:'est',  label:'Trust & Estate'},
          {key:'ret',  label:'Retirement'},
          {key:'alt',  label:'Alternatives'},
        ].map(c => (
          <button class={`chip${c.key==='all'?' on':''}`} data-filter={c.key}>{c.label}</button>
        ))}
      </div>

      <div class="srv-grid rv" id="srvGrid">
        {[
          {key:'inv', n:'01', id:'investment',  t:'Investment Management',  d:'Bespoke portfolio construction driven by data and disciplined risk management — built from scratch for your objectives.'},
          {key:'plan',n:'02', id:'planning',    t:'Financial Planning',      d:'A comprehensive financial blueprint across retirement, cash flow, insurance, education, and legacy — revisited as life evolves.'},
          {key:'tax', n:'03', id:'tax',         t:'Tax Optimization',        d:'Tax strategy embedded into every investment decision — minimising liabilities, maximising after-tax wealth.'},
          {key:'est', n:'04', id:'estate',      t:'Trust & Estate Planning', d:'Precision-structured strategies — CRTs, GRATs, SLATs — to protect and transfer wealth across generations.'},
          {key:'ret', n:'05', id:'retirement',  t:'Retirement Planning',     d:'Sustainable income architecture designed to support your lifestyle for life — regardless of market conditions.'},
          {key:'alt', n:'06', id:'alternatives',t:'Alternative Investments', d:'Curated access to private equity, real assets, and hedge strategies — rigorously vetted and portfolio-integrated.'},
        ].map(s => (
          <a href={`/services#${s.id}`} class="srv-card" data-key={s.key}>
            <span class="sc-bg-num" aria-hidden="true">{s.n}</span>
            <span class="sc-num">{s.n}</span>
            <span class="sc-t">{s.t}</span>
            <span class="sc-d">{s.d}</span>
            <span class="sc-arr">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="rv" style="margin-top:36px">
        <a href="/services" class="btn-outline">Explore All Services →</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about-section">
    <div class="about-photo rv">
      <img src="/images/photo-office-detail.jpg" alt="RADIANX CAPITAL workspace" loading="lazy"/>
    </div>
    <div class="about-copy">
      <div class="ls-tag rv">Our Philosophy</div>
      <h2 class="ls-h rv" style="margin-bottom:24px">Capital managed<br>with <em>exactitude</em></h2>
      <p class="ls-body rv">At RADIANX CAPITAL, lasting wealth is built on clarity, discipline, and precision. We construct strategies that endure market cycles and life transitions alike.</p>
      <p class="ls-body rv">As a fully registered fiduciary, our sole obligation is to you. No hidden incentives. No commissions. Transparent counsel calibrated to your long-term interests.</p>
      <ul class="val-grid rv">
        {[
          {n:'01', t:'Fiduciary by Design',   d:'Legally bound to act in your best interest. No conflicts, no commissions.'},
          {n:'02', t:'Institutional Rigor',    d:'Analytical standards of the world\'s leading institutions — with personal attention.'},
          {n:'03', t:'Transparent Fees',       d:'Fees are clear. Communication is open. No surprises, ever.'},
          {n:'04', t:'Long-Term Thinking',     d:'Every decision made through a long-term lens — resistant to noise and sentiment.'},
        ].map(v => (
          <li class="val-item">
            <span class="val-n">{v.n}</span>
            <div><div class="val-t">{v.t}</div><div class="val-d">{v.d}</div></div>
          </li>
        ))}
      </ul>
      <a href="/about" class="btn-outline rv">About the Firm →</a>
    </div>
  </section>

  <!-- TEAM -->
  <section class="light-section" id="team">
    <div class="ls-inner">
      <div class="ls-tag rv">Leadership</div>
      <h2 class="ls-h rv" style="margin-bottom:48px">The people behind<br><em>your capital</em></h2>
      <div class="team-grid">
        {[
          {img:'/images/photo-li-tan.jpg',       init:'LT', role:'Principal',          name:'Li Tan',       title:'Co-Founder & Managing Principal', bio:'Over 30 years of investment management experience. Specialises in tax-efficient portfolio construction and long-term wealth architecture for high-net-worth families.'},
          {img:'/images/photo-david-su.jpg',      init:'DS', role:'Principal',          name:'David Su',     title:'Co-Founder & Senior Adviser',     bio:'Three decades serving high-net-worth families. Focuses on retirement income architecture, estate planning coordination, and complex financial transitions.'},
          {img:'/images/photo-douglas-beyer.jpg', init:'DB', role:'Investment Adviser', name:'Douglas Beyer',title:'Investment Adviser & Analyst',     bio:'Combines analytical rigour with a contemporary approach to portfolio research. Focuses on high-conviction opportunities and optimal portfolio positioning.'},
        ].map((m,i) => (
          <div class={`tm-card rv${i>0?` d${i}`:''}`}>
            <div class="tm-inner">
              <div class="tm-front">
                <div class="tm-photo">
                  <img src={m.img} alt={m.name} width="72" height="72" loading="lazy"
                    onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}/>
                  <span class="tm-init" style="display:none">{m.init}</span>
                </div>
                <div class="tm-role">{m.role}</div>
                <div class="tm-name">{m.name}</div>
                <div class="tm-title">{m.title}</div>
                <p class="tm-bio">{m.bio}</p>
                <span class="tm-hover-hint">Hover to connect →</span>
              </div>
              <div class="tm-back">
                <div class="tm-back-name">{m.name}</div>
                <div class="tm-back-title">{m.title}</div>
                <div class="tm-back-divider"></div>
                <p class="tm-back-bio">{m.bio}</p>
                <a href="/contact" class="tm-back-cta">Schedule a Call →</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- APPROACH — dark band -->

  <!-- ══ TESTIMONIALS ══ -->
  <section class="testi-section">
    <div class="testi-inner">
      <div class="testi-head rv">
        <div class="ls-tag">Client Perspectives</div>
        <h2 class="ls-h">What our clients<br><em>experience</em></h2>
      </div>
      <div class="testi-grid">
        <div class="testi-card rv">
          <div class="testi-quote-mark">"</div>
          <div class="testi-stars">★★★★★</div>
          <p class="testi-text">RADIANX transformed how I think about my wealth. For the first time, everything — investments, taxes, estate — works as one coherent strategy. The clarity alone is worth it.</p>
          <div class="testi-reveal">
            <div class="testi-reveal-line"></div>
          </div>
          <div class="testi-author">
            <div class="testi-avatar">ST</div>
            <div>
              <div class="testi-name">Senior Technology Executive</div>
              <div class="testi-meta">Client since 2019 · New York</div>
            </div>
          </div>
        </div>
        <div class="testi-card rv d1">
          <div class="testi-quote-mark">"</div>
          <div class="testi-stars">★★★★★</div>
          <p class="testi-text">I've worked with three advisers over the years. None came close to the rigor and transparency RADIANX brings. They think about my money the way I think about my business — long-term, methodically.</p>
          <div class="testi-author">
            <div class="testi-name">Private Equity Partner</div>
            <div class="testi-meta">Client since 2020 · New York</div>
          </div>
        </div>
        <div class="testi-card rv d2">
          <div class="testi-quote-mark">"</div>
          <div class="testi-stars">★★★★★</div>
          <p class="testi-text">What sets RADIANX apart is that they actually explain every decision. I understand my portfolio, my tax strategy, and my plan. No black boxes. That trust is rare in this industry.</p>
          <div class="testi-author">
            <div class="testi-name">Healthcare Founder</div>
            <div class="testi-meta">Client since 2021 · New Jersey</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="approach-band">
    <div class="ab-inner">
      <div class="ab-left">
        <div class="dk-tag rv">How We Work</div>
        <h2 class="dk-h rv">A disciplined<br><em>four-step process</em></h2>
        <p class="dk-body rv">From first conversation to ongoing stewardship — a structured process that produces consistent, disciplined outcomes for every client.</p>
        <a href="/approach" class="btn-dark rv">Full Methodology →</a>
      </div>
      <div class="steps-grid">
        {[
          {n:'01',t:'Discovery',   d:'An unhurried conversation about your full financial life — goals, concerns, timeline, and what wealth means to you.'},
          {n:'02',t:'Architecture',d:'A comprehensive financial blueprint — tax-efficient, risk-calibrated, built precisely around your circumstances.'},
          {n:'03',t:'Execution',   d:'Institutional-grade implementation — every position, every tax implication managed with precision.'},
          {n:'04',t:'Stewardship', d:'Daily monitoring, annual reviews — your strategy evolves continuously as your life does.'},
        ].map((s,i) => (
          <div class={`step-card rv${i>0?` d${i}`:''}`}>
            <div class="step-n">{s.n}</div>
            <div class="step-t">{s.t}</div>
            <div class="step-d">{s.d}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REG BAR -->
  <div class="reg-bar">
    <div class="rb-items rv">
      {[
        {l:'SEC',     v:'No. 801-117100'},
        {l:'CRD',     v:'298178'},
        {l:'EIN',     v:'82-3414149'},
        {l:'Founded', v:'November 2017'},
        {l:'Office',  v:'529 5th Ave, Suite 1475, New York'},
      ].map(r => (
        <div class="rb-item">
          <span class="rb-l">{r.l}</span>
          <span class="rb-v">{r.v}</span>
        </div>
      ))}
    </div>
    <div class="rb-pills rv">
      {['Fiduciary · Always','Fee-Only','SEC Registered','Form ADV Available'].map(p => (
        <span class="rb-pill">{p}</span>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <h2 class="dk-h rv" style="max-width:560px">Your wealth deserves<br><em>precise attention.</em></h2>
      <div class="cta-right rv">

        <p class="cta-note">529 5th Avenue, Suite 1475 · New York, NY 10017<br>Complimentary consultation for qualified prospective clients.</p>
      </div>
    </div>
