  .srv-grid,.team-grid,.steps-grid{grid-template-columns:1fr}
  .ab-inner,.cta-section,.reg-bar{padding-left:20px;padding-right:20px}
  .photo-year{display:none}
  .photo-strip-txt{left:20px}
  .hero{padding:120px 20px 80px}
}

/* ══ PRESS MARQUEE ══ */
.press-bar {
  background: var(--white);
  border-bottom: 1px solid var(--rule);
  padding: 18px 0;
  display: flex;
  align-items: center;
  gap: 32px;
