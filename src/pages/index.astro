  font-family: 'DM Mono', monospace;
  font-size: 8.5px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--ink3);
}
.pb-divider {
  width: 1px; height: 60px;
  background: var(--rule); flex-shrink: 0;
}

/* Responsive */
