.sbar:hover { background: #faf9f6; }
.sbar::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--navy); transform: scaleX(0); transform-origin: left;
  transition: transform .45s;
}
