<style>
/* ── Shell ── */
footer {
  background: #0c0d11;
  border-top: 1px solid rgba(238,240,245,.06);
  font-family: 'Outfit', sans-serif;
}

/* ── Main grid: brand (wider) + 3 nav cols ── */
.f-main {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 0;
  padding: 64px 64px 56px;
  border-bottom: 1px solid rgba(238,240,245,.05);
}

/* ── Brand column ── */
.f-brand {
  padding-right: 64px;
  border-right: 1px solid rgba(238,240,245,.05);
  display: flex;
  flex-direction: column;
  gap: 0;
}

.f-logo {
  height: 56px;
  width: auto;
  max-width: 180px;
  object-fit: contain;
  display: block;
  margin-bottom: 20px;
  filter: brightness(0) invert(1);
  opacity: 0.75;
}

.f-tagline {
  font-size: 13px;
  font-weight: 300;
  color: rgba(238,240,245,.32);
  line-height: 1.8;
  margin-bottom: 22px;
}

/* Social icons */
.f-social {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}

.f-soc {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 6px;
  border: 1px solid rgba(238,240,245,.08);
  background: rgba(238,240,245,.04);
  color: rgba(238,240,245,.35);
  text-decoration: none;
  transition: background .2s, color .2s, border-color .2s, transform .15s;
}
.f-soc:hover {
  background: rgba(238,240,245,.1);
  border-color: rgba(238,240,245,.18);
  color: #eef0f5;
  transform: translateY(-2px);
}

.f-reg {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  color: rgba(238,240,245,.18);
  line-height: 2;
}

/* ── Nav columns (3 in a row) ── */
.f-nav-cols {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
  padding-left: 64px;
}

.f-col {
  padding: 0 32px 0 0;
}
.f-col:last-child { padding-right: 0; }

.f-col-h {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(238,240,245,.28);
  margin-bottom: 20px;
}

.f-links {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.f-links a {
  font-size: 13.5px;
  font-weight: 300;
  color: rgba(238,240,245,.38);
  text-decoration: none;
  transition: color .2s;
}
.f-links a:hover { color: #eef0f5; }

/* Contact items */
.f-contact {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.f-ci {
  font-size: 13px;
  font-weight: 300;
  color: rgba(238,240,245,.38);
  line-height: 1.7;
}
.f-ci-label {
  display: block;
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: rgba(238,240,245,.28);
  margin-bottom: 5px;
}
.f-ci a {
  color: rgba(238,240,245,.38);
  text-decoration: none;
  transition: color .2s;
}
.f-ci a:hover { color: #eef0f5; }

/* ── Bottom bar ── */
.f-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  padding: 20px 64px;
  flex-wrap: wrap;
}

.f-disc {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: .7px;
  color: rgba(238,240,245,.14);
  line-height: 2;
  max-width: 780px;
}

.f-url {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 2.5px;
  color: rgba(238,240,245,.14);
  white-space: nowrap;
  flex-shrink: 0;
}

/* ── Responsive ── */
@media (max-width: 1100px) {
  .f-main {
    grid-template-columns: 1fr;
    padding: 48px 40px 40px;
    gap: 40px;
  }
  .f-brand {
    border-right: none;
    border-bottom: 1px solid rgba(238,240,245,.05);
    padding-right: 0;
    padding-bottom: 40px;
  }
  .f-nav-cols {
    padding-left: 0;
    gap: 32px;
  }
  .f-bottom { padding: 18px 40px; }
}

@media (max-width: 768px) {
  .f-main { padding: 40px 24px 32px; }
  .f-nav-cols { grid-template-columns: 1fr 1fr; }
  .f-bottom { padding: 16px 24px; }
}

@media (max-width: 480px) {
  .f-nav-cols { grid-template-columns: 1fr; gap: 28px; }
  .f-main { padding: 36px 20px 28px; }
  .f-bottom { padding: 14px 20px; }
}




/* ── Trustpilot bar ── */
.tp-bar {
  background: #0a0b0e;
  border-bottom: 1px solid rgba(238,240,245,.06);
  padding: 20px 64px;
}
.tp-bar-inner {
  max-width: 1320px;
  margin: 0 auto;
  display: flex;
  align-items: center;
}
.tp-badge {
  display: flex;
  align-items: center;
  gap: 16px;
  text-decoration: none;
  transition: opacity .2s;
}
.tp-badge:hover { opacity: .8; }
.tp-badge-logo {
  display: flex;
  align-items: center;
  gap: 8px;
}
.tp-badge-name {
  font-family: 'Outfit', sans-serif;
  font-size: 15px;
  font-weight: 500;
  color: #fff;
  letter-spacing: -.2px;
}
.tp-badge-stars {
  display: flex;
  gap: 2px;
}
.tp-star {
  color: #00B67A;
  font-size: 18px;
  line-height: 1;
}
.tp-badge-text {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(238,240,245,.3);
  border-left: 1px solid rgba(238,240,245,.1);
  padding-left: 16px;
}
@media (max-width: 768px) {
  .tp-bar { padding: 16px 24px; }
  .tp-badge-text { display: none; }
}
@media (max-width: 480px) {
  .tp-bar { padding: 14px 20px; }
}


/* ── Footer Trustpilot inline ── */
.f-tp {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  margin-bottom: 20px;
  transition: opacity .2s;
}
.f-tp:hover { opacity: .75; }
.f-tp-name {
  font-family: 'Outfit', sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: rgba(238,240,245,.55);
}
.f-tp-stars {
  color: #00B67A;
  font-size: 13px;
  letter-spacing: 1px;
}

</style>
